# ────────────────────────────────────────────────────────────
# Jarvis Dashboard & Agent Suite — Unified Environment
# Copy this to .env and fill in your real values
# ────────────────────────────────────────────────────────────

# ── AI Provider Keys (used by IntelligenceChat UI) ──
# These are served to the client via /api/keys so they persist
# beyond localStorage (survives cache clear, incognito, etc.)
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=your_gemini_key
OPENROUTER_API_KEY=your_openrouter_key
GROQ_API_KEY=your_groq_key
DEEPSEEK_API_KEY=your_deepseek_key

# ── Supabase (data layer for both dashboard & agents) ──
SUPABASE_URL=https://afwdfyofjcpbyydbxntr.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# ── ElevenLabs (voice AI) ──
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_AGENT_ID=agent_...
ELEVENLABS_PHONE_ID=phnum_...

# ── Twilio (phone system) ──
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE=+1...

# ── Telegram (bot notifications) ──
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# ── GHL (GoHighLevel CRM) ──
GHL_API_TOKEN=pit-...

# ── Telnyx (backup phone provider) ──
TELNYX_API_KEY=KEY...
TELNYX_CONNECTION_ID=...
TELNYX_CC_APP_ID=...

# ── DealMachine (price enrichment) ──
DEALMACHINE_EMAIL=...
DEALMACHINE_PASSWORD=...

# ── XLeads / Speed to Lead ──
XLEADS_EMAIL=...
XLEADS_PASSWORD=...
SPEED_TO_LEAD_API_KEY=...
STL_EMAIL=...
STL_PASSWORD=...
STL_PORT=3006

# ── Webhook / Cloudflare Tunnel ──
CLOUDFLARE_URL=...
WEBHOOK_URL=...

# ── Phone numbers ──
MY_PHONE=+1...
DAVID2_PHONE=+1...
DAVID3_PHONE=+1...
DAVID4_PHONE=+1...
DAVID5_PHONE=+1...

# ── Flags ──
CLAUDE_AUTO_ANALYSIS=true
QA_SECRET=asaparv-qa-...